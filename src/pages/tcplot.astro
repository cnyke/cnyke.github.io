---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="tcplot() | Claire Nyquist"
    description="tcplot() — a meetup group for data visualization enthusiasts exploring creative and scientific plotting."
    image="/images/nobelPrizes.jpeg"
>
    <div class="bg-black flex-1">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <!-- Header -->
            <div class="mb-4">
                <h1 class="text-4xl font-semibold text-stone-100 mb-4">tcplot()</h1>
                <p class="text-lg text-stone-300 leading-relaxed">
                    tcplot() is a Twin Cities community for data visualization
                    practitioners, enthusiasts, and storytellers. Whether you are a
                    D3 wizard, a Tableau pro, a ggplot2 devotee, or someone who
                    appreciates a well-crafted chart, you've found your people.
                </p>
            </div>

            <!-- Hero Image -->
            <div class="mb-12 rounded-lg overflow-hidden shadow-lg">
                <img
                    src="/images/tcplot.jpeg"
                    alt="Nobel Prizes data visualization — a colorful tile plot on a dark background"
                    class="w-full object-cover"
                />
            </div>

            <!-- About Section -->
            <div class="max-w-none">
                <p class="text-stone-300 leading-relaxed mb-6">
                    Our mission is to elevate the data literacy and design standards
                    of the MSP area through three core pillars:
                </p>
                <ul class="space-y-3 text-stone-300 mb-6">
                    <li class="flex items-start gap-2">
                        <span class="mt-1 text-blue-400">▸</span>
                        <span
                            ><strong class="text-stone-100">Talks:</strong> Hear from local experts and industry
                            leaders on the "why" and "how" of great visualization.</span
                        >
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="mt-1 text-blue-400">▸</span>
                        <span
                            ><strong class="text-stone-100">Workshops:</strong> Roll up your sleeves for hands-on
                            sessions where we master new tools, libraries, and design
                            principles.</span
                        >
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="mt-1 text-blue-400">▸</span>
                        <span
                            ><strong class="text-stone-100">Build-a-thons:</strong> Join collaborative coworking
                            where we take datasets and turn them into impactful, interactive,
                            or artistic visual stories.</span
                        >
                    </li>
                </ul>
            </div>

            <!-- Links -->
            <div class="flex justify-center gap-6 mt-12">
                <a
                    href="https://www.instagram.com/tcplot/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-400 hover:underline font-medium"
                >
                    Instagram
                </a>
                <a
                    href="https://www.meetup.com/tcplot/?eventOrigin=home_groups_you_organize"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-400 hover:underline font-medium"
                >
                    Meetup
                </a>
            </div>
        </div>
    </div>
</BaseLayout>
