---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="tcplot() | Claire Nyquist"
    description="tcplot() — a meetup group for data visualization enthusiasts exploring creative and scientific plotting."
    image="/images/tcplot(whale).png"
>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="text-center mb-12">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">tcplot(🎨💻🎤)</h1>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
                tcplot() is a Twin Cities community for data visualization
                practitioners, enthusiasts, and storytellers. Whether you are a
                D3 wizard, a Tableau pro, a ggplot2 devotee, or someone who
                appreciates a well-crafted chart, you've found your people.
            </p>
        </div>

        <!-- Petri Image -->
        <div class="flex justify-center mb-12">
            <div class="max-w-2xl w-full rounded-lg overflow-hidden">
                <img
                    src="/images/tcplot(petriwithtext).png"
                    alt="tcplot() data visualization twin cities — collage featuring a scientist with a petri dish, eclipse, and time series chart"
                    class="w-full h-auto object-contain"
                />
            </div>
        </div>

        <!-- About Section -->
        <div class="max-w-4xl mx-auto mb-12">
            <p class="text-lg text-gray-600 leading-relaxed mb-6">
                Our mission is to elevate the data literacy and design standards
                of the MSP area through three core pillars:
            </p>
            <ul class="space-y-3 text-gray-600 mb-6">
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">▸</span>
                    <span
                        ><strong class="text-gray-900">Talks:</strong> Hear from local experts and industry
                        leaders on the "why" and "how" of great visualization.</span
                    >
                </li>
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">▸</span>
                    <span
                        ><strong class="text-gray-900">Workshops:</strong> Roll up your sleeves for hands-on
                        sessions where we master new tools, libraries, and design
                        principles.</span
                    >
                </li>
                <li class="flex items-start gap-2">
                    <span class="mt-1 text-gray-400">▸</span>
                    <span
                        ><strong class="text-gray-900">Build-a-thons:</strong> Join collaborative coworking
                        where we take datasets and turn them into impactful, interactive,
                        or artistic visual stories.</span
                    >
                </li>
            </ul>
        </div>

        <!-- Links -->
        <div class="flex justify-center gap-6 mt-12">
            <a
                href="https://www.instagram.com/tcplot/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:underline font-medium"
            >
                Instagram
            </a>
            <a
                href="https://www.meetup.com/tcplot/?eventOrigin=home_groups_you_organize"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:underline font-medium"
            >
                Meetup
            </a>
        </div>

        <!-- Whale Image -->
        <div class="flex justify-center mt-12">
            <div class="max-w-4xl w-full rounded-lg overflow-hidden">
                <img
                    src="/images/tcplot(whale).png"
                    alt="tcplot() data visualization twin cities — collage featuring a whale, scatter plot, heatmap, and neuron illustration"
                    class="w-full h-auto object-contain"
                />
            </div>
        </div>
    </div>

</BaseLayout>
